            <tbody>
                <?php foreach ($profiles as $p): ?>
                <tr>
                    <td><?= $esc($p['label']) ?></td>
                    <td><code style="font-size:0.8em;"><?= $esc($truncateSql($p['sql'])) ?></code></td>
                    <td style="text-align:right;"><?= $esc($fmt($p['elapsed_ms'])) ?></td>
                    <td style="text-align:right;"><?= $p['wall_start'] !== null ? date('H:i:s.', (int)$p['wall_start']) . str_pad((string)round(fmod($p['wall_start'], 1) * 1000), 3, '0', STR_PAD_LEFT) : '—' ?></td>
