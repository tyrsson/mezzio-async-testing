<?php

declare(strict_types=1);

/**
 * @var array  $profiles    [ ['label'=>string, 'sql'=>string, 'elapsed_ms'=>float|null, 'wall_start'=>float|null] ]
 * @var float  $totalMs     Wall time for the full await_all_or_fail block (ms)
 * @var array  $users       Rows from bm_users
 * @var array  $products    Rows from bm_products
 * @var array  $orders      Rows from bm_orders (with username)
 * @var array  $topProducts Top products by revenue
 */

$fmt = static fn(?float $ms): string => $ms !== null ? number_format($ms, 3) . ' ms' : '—';
$esc = static fn(string $v): string => htmlspecialchars($v, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');
$truncateSql = static function (string $sql): string {
    $sql = preg_replace('/\s+/', ' ', trim($sql));
    return strlen($sql) > 120 ? substr($sql, 0, 117) . '...' : $sql;
};

$this->layout('layout::default', ['title' => 'PostgreSQL Benchmark']);
?>

<main class="container" style="margin-top: 2rem;">

    <hgroup>
        <h1>PostgreSQL Concurrent Query Benchmark</h1>
        <p>Four independent SELECT queries executed as concurrent TrueAsync coroutines via <code>await_all_or_fail()</code>.</p>
